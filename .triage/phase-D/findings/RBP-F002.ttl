<urn:atm:triage:finding/RBP-F002>
  a triage:Finding ;
  triage:findingId "RBP-F002" ;
  triage:title "forbidden_edges specified as delimited strings instead of structured TOML" ;
  triage:description "forbidden_edges is specified as delimited strings (\"package-a -> package-b\") rather than structured TOML (e.g. inline tables { from = ..., to = ... }), requiring a parsing/validation step for data TOML can represent natively and duplicating the already-planned ForbiddenPackageEdge { from, to } runtime type. Remediation: model as inline tables directly." ;
