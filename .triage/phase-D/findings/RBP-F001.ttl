<urn:atm:triage:finding/RBP-F001>
  a triage:Finding ;
  triage:findingId "RBP-F001" ;
  triage:title "sprint-D1.md dependency-policy validation errors lack structured error type/stable code" ;
  triage:description "docs/phase-D/sprint-D1.md:162 -- RawDependenciesSection::validate() return type is specified only as Result<PackageDependencyPolicy> without an error variant. No structured validation-error type or stable error code is defined, nor is it mapped to the CliError taxonomy in docs/sc-lint/cli-contract.md:231-244. Remediation: define explicit validation-error variants (e.g., ParseError, DuplicateEdge, UnknownPackage, etc.) and map them into the existing CONFIG_ERROR family for actionable error reporting." ;
  triage:phaseId "phase-D" ;
  triage:triageMode "initial_pass" ;
