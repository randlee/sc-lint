# ============================================================
# Finding: ARCH-013
# Six shared types duplicated verbatim in sc-lint-runtime — RULE-005
# Triaged: 2026-05-10T00:00:00Z
# ============================================================

<urn:atm:triage:finding/ARCH-013>
  a triage:Finding ;
  triage:findingId "ARCH-013" ;
  triage:title "Six shared types duplicated verbatim in sc-lint-runtime — RULE-005" ;
  triage:description "sc-lint-runtime/src/lib.rs defines OutputFormat (line 21), NodeId (line 58), OwnerId (line 94), FindingsReport (line 129), ReportStatus (line 140), Finding (line 155) — identical to the same-named types in sc-lint-boundary/src/lib.rs. RULE-005 forbids duplicate struct/enum definitions across crates." ;
  triage:category "ARCH" ;
  triage:phaseId "phase-A" ;
  triage:triageMode "initial_pass" ;
  triage:severity "blocking" ;
  triage:repeatable true ;
  triage:sweepScope "workspace" ;
