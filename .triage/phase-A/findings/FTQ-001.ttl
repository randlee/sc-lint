# ── Finding ──────────────────────────────────────────────────────────────────

<urn:atm:triage:finding/FTQ-001>
  a triage:Finding ;
  triage:findingId "FTQ-001" ;
  triage:title "lint_sc_boundary and lint_sc_runtime tests use live workspace_root() instead of hermetic fixture" ;
  triage:description "crates/sc-lint/src/tests.rs contains lint_sc_boundary_normalizes_backend_success_through_the_top_level_envelope and lint_sc_runtime_normalizes_backend_success_through_the_top_level_envelope which call workspace_root() — the live feature worktree — and assert json['ok'] == true. If the real codebase has boundary or runtime findings at test time, assertions flip to failure. Fix: replace live workspace_root() with a hermetic WorkspaceFixture containing known-clean synthetic source." ;
  triage:triageMode "initial_pass" ;
  triage:category "FTQ" ;
  triage:phaseId "phase-A" ;
  triage:severity "important" ;
  triage:repeatable true ;
  triage:sweepScope "crate" ;
  triage:pattern "workspace_root\\(\\)" ;
  triage:fileFilter "tests\\.rs" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:references "PR #15" , "QA-A5-001 FAIL" , "flaky-test-qa findings FTQ-001/002" ;
  triage:notes "Both FTQ-001 and FTQ-002 have the same root cause (workspace_root() in sc-lint/src/tests.rs) so they share this triage record. Sweep confirmed open on sprint-A4, sprint-A5, sprint-A6, sprint-A7. sprint-A8 has no sc-lint crate (absent). write_workspace_root() calls in sc-lint-boundary and sc-lint-portability tests are hermetic fixture methods and are NOT occurrences of this finding." ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A4/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A4/2> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A5/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A5/2> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A6/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A6/2> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A7/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-001/sprint-A7/2> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A4/aac4dea> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A5/a392088> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A6/8544597> ;
