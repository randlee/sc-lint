# Finding: A5-NEW-003
# "sc-lint-runtime" bare string literals in dispatch.rs and command.rs — no constants in consts.rs
# Source: QA-A5-001 arch-qa finding SC-QA-003 (quality-mgr naming)
# Triaged: 2026-05-10T00:00:00Z

<urn:atm:triage:finding/A5-NEW-003>
  a triage:Finding ;
  triage:findingId "A5-NEW-003" ;
  triage:title "'sc-lint-runtime' bare string literal repeated in dispatch.rs and command.rs — no TOOL_RUNTIME constant" ;
  triage:description "crates/sc-lint/src/dispatch.rs:98 (`let tool = \"sc-lint-runtime\";`) and :105 (`\"sc-lint-runtime\",`) and crates/sc-lint/src/command.rs:175 (`Self::LintScRuntime => Some(\"sc-lint-runtime\"),`) use bare string literals for the runtime tool name. No TOOL_RUNTIME or CMD_RUNTIME constant exists in crates/sc-lint/src/consts.rs. Fix: add a TOOL_RUNTIME constant (and/or CMD_RUNTIME) to consts.rs and replace all three bare literals." ;
  triage:category "ARCH" ;
  triage:phaseId "phase-A" ;
  triage:triageMode "initial_pass" ;
  triage:severity "important" ;
  triage:repeatable false ;
  triage:sweepScope "crate" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:notes "Occurrences are on feature/sprint-A5 only — sc-lint-runtime was added in sprint A5. Not present on integration/phase-A (A4 base). Absent from A6-A8 at triage time. Fix on A5; propagates via merge-forward. Note: command.rs line numbers may shift after merge-forward from integration/phase-A into A5 — treat file+context as the invariant, not line numbers." ;
