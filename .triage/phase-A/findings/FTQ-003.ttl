<urn:atm:triage:finding/FTQ-003>
  a triage:Finding ;
  triage:findingId "FTQ-003" ;
  triage:title "logger_bootstrap integration test not #[serial] and lacks ATM_HOME/ATM_CONFIG_HOME isolation" ;
  triage:description "crates/sc-lint/tests/logging_integration.rs: logger_bootstrap_writes_entry_completion_dispatch_and_error_records at line 9/10/11 is not marked #[serial] but spawns multiple sc-lint subprocesses against the live repo_root, contending with concurrent workspace tests. On sprint-A5 through sprint-A7 no subprocess receives ATM_HOME or ATM_CONFIG_HOME env overrides (RULE-011 isolation absent). sprint-A4 has ATM isolation via clear_atm_env but still lacks #[serial]." ;
  triage:triageMode "initial_pass" ;
  triage:category "FTQ" ;
  triage:phaseId "phase-A" ;
  triage:severity "important" ;
  triage:repeatable false ;
  triage:sweepScope "file_only" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-003/sprint-A4/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-003/sprint-A5/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-003/sprint-A6/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-003/sprint-A7/1> ;
