<urn:atm:triage:finding/FTQ-004>
  a triage:Finding ;
  triage:findingId "FTQ-004" ;
  triage:title "xwin_logging test not #[serial] creates PATH TOCTOU race" ;
  triage:description "crates/sc-lint/tests/logging_integration.rs: xwin_logging_records_target_metadata_for_success_and_error_paths reads std::env::var_os(\"PATH\") without holding a serial lock, creating a TOCTOU race with #[serial]-marked tests that may modify the process environment. Fix: mark this test #[serial]." ;
  triage:phaseId "phase-A" ;
  triage:triageMode "initial_pass" ;
  triage:category "FTQ" ;
  triage:severity "important" ;
  triage:repeatable false ;
  triage:sweepScope "file_only" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:hasOccurrence <urn:atm:triage:occurrence/FTQ-004/sprint-A4/1> ;
