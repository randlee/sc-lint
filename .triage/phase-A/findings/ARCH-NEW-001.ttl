<urn:atm:triage:finding/ARCH-NEW-001>
  a triage:Finding ;
  triage:findingId "ARCH-NEW-001" ;
  triage:title "mod logging declared in lib.rs violates RULE-001" ;
  triage:description "lib.rs declares `mod logging`, making logging.rs a library module. logging.rs imports sc_observability directly (lines 5-19). RULE-001 (ADR-008) confines sc-observability imports to main.rs/logging.rs binary modules only. Library modules must not import sc_observability." ;
  triage:triageMode "initial_pass" ;
  triage:category "ARCH" ;
  triage:phaseId "phase-A" ;
  triage:severity "blocking" ;
  triage:repeatable false ;
  triage:sweepScope "file_only" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:hasOccurrence <urn:atm:triage:occurrence/ARCH-NEW-001/sprint-A4/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/ARCH-NEW-001/sprint-A5/1> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A4/b60b763> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A5/d4c847a> ;
  triage:promoteTo <urn:atm:triage:worktree/sprint-A5/d4c847a> .

