# Finding: RBP-F001
# FileContext.package and .target use plain String instead of PackageName/TargetName newtypes
# Phase: phase-A | Mode: initial_pass | Triaged: 2026-05-10T00:00:00Z

<urn:atm:triage:finding/RBP-F001>
  a triage:Finding ;
  triage:findingId "RBP-F001" ;
  triage:title "FileContext.package and .target use plain String instead of PackageName/TargetName newtypes" ;
  triage:description "crates/sc-lint-runtime/src/source_scan.rs: FileContext has pub(crate) package: String and target: String. Both represent semantically distinct Cargo identifiers (package name vs target name) but share the same String type, allowing silent mixing at call sites. RuntimeFinding repeats the same pair. Node-id assembly in runtime.rs (lines 88-93, 251-252, 270-271) interleaves them manually with no type enforcement. Fix: introduce PackageName and TargetName newtypes with validated constructors." ;
  triage:triageMode "initial_pass" ;
  triage:category "ARCH" ;
  triage:phaseId "phase-A" ;
  triage:severity "important" ;
  triage:repeatable true ;
  triage:sweepScope "crate" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:hasOccurrence <urn:atm:triage:occurrence/RBP-F001/sprint-A5/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/RBP-F001/sprint-A5/2> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/RBP-F001/sprint-A5/3> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/RBP-F001/sprint-A5/4> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A5/a392088> ;
  triage:promoteTo <urn:atm:triage:worktree/sprint-A5/a392088> .

