<urn:atm:triage:finding/ARCH-006>
  a triage:Finding ;
  triage:findingId "ARCH-006" ;
  triage:title "Hardcoded /tmp/ fixture strings lack PORT-001 detection intent comments" ;
  triage:description "tests.rs lines 67, 136, and 351 contain hardcoded /tmp/ path strings used as fixtures. PORT-001 (portability rule) flags hardcoded /tmp/ paths. These occurrences are intentional test fixtures but lack a comment explaining the PORT-001 detection intent, making it unclear whether they are intentional exemptions or oversight." ;
  triage:triageMode "initial_pass" ;
  triage:category "ARCH" ;
  triage:phaseId "phase-A" ;
  triage:severity "important" ;
  triage:repeatable true ;
  triage:sweepScope "crate" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
