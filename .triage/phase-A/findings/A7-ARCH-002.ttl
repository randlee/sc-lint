<urn:atm:triage:finding/A7-ARCH-002>
  a triage:Finding ;
  triage:findingId "A7-ARCH-002" ;
  triage:title "RULE-010: 'team-lead' raw string literal repeated in test files without named constant" ;
  triage:description "test_lint_identity_literals.py has 6+ occurrences of the bare string 'team-lead' and test_lint_common.py also contains it, without a centralized named constant. RULE-010 requires well-known identifier strings to be defined as named constants, not repeated as literals. Fix: add a constant (e.g. TEAM_LEAD_IDENTITY = 'team-lead') in a shared fixture module or consts.py and replace all raw literals." ;
