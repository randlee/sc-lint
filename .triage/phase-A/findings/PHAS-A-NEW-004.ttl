<urn:atm:triage:finding/PHAS-A-NEW-004>
  a triage:Finding ;
  triage:findingId "PHAS-A-NEW-004" ;
  triage:title "workspace_root() used as current_dir for subprocess invocations in logging_integration.rs" ;
  triage:description "crates/sc-lint/tests/logging_integration.rs uses workspace_root() as current_dir for all sc_lint_command subprocess invocations. This is a residual live-worktree isolation risk beyond the FTQ-001 fix scope. Tests may fail or produce different results depending on which worktree they run from." ;
  triage:triageMode "initial_pass" ;
  triage:category "SC" ;
  triage:phaseId "phase-A" ;
  triage:severity "important" ;
  triage:repeatable false ;
  triage:sweepScope "file_only" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
