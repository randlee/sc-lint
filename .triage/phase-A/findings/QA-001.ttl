@prefix triage: <urn:atm:triage:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<urn:atm:triage:finding/QA-001>
  a triage:Finding ;
  triage:findingId "QA-001" ;
  triage:title "anyhow::Error leaks into public RuntimeError API via struct variant source fields" ;
  triage:description "crates/sc-lint-runtime/src/lib.rs defines pub enum RuntimeError with two struct variants (AnalyzeFindings, CountScannedCrates) each containing `source: AnyhowError` where AnyhowError = anyhow::Error. Enum struct-variant fields inherit the enum's pub visibility, making anyhow part of the public API surface. Library crates must not expose anyhow at public API boundaries. Fix: replace source: AnyhowError with a concrete typed error (e.g. BoxedError or per-variant typed sub-errors), or mark fields pub(crate)." ;
  triage:phaseId "phase-A" ;
  triage:triageMode "initial_pass" ;
  triage:category "ARCH" ;
  triage:severity "important" ;
  triage:repeatable false ;
  triage:sweepScope "crate" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:hasOccurrence <urn:atm:triage:occurrence/QA-001/sprint-A5/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/QA-001/sprint-A5/2> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/QA-001/sprint-A5/3> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A5/a392088> ;
  triage:promoteTo <urn:atm:triage:worktree/sprint-A5/a392088> .

