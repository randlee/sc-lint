<urn:atm:triage:finding/QA-001>
  a triage:Finding ;
  triage:findingId "QA-001" ;
  triage:title "anyhow::Error exposed in public RuntimeError API via struct variant field" ;
  triage:description "crates/sc-lint-runtime/src/lib.rs:72-86 pub enum RuntimeError has struct variant fields `source: AnyhowError` (where AnyhowError = anyhow::Error) that inherit the enum's pub visibility. PHAS-A-NEW-005 fix changed detail:String to #[source] source:AnyhowError but did not address the public visibility of anyhow::Error in the public API surface." ;
  triage:phaseId "phase-A" ;
  triage:triageMode "followup_pass" ;
  triage:category "SC" ;
  triage:severity "important" ;
  triage:repeatable false ;
  triage:sweepScope "crate" ;
  triage:status "open" ;
  triage:dispatchReady true ;
