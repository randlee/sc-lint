<urn:atm:triage:finding/A6-ARCH-002>
  a triage:Finding ;
  triage:findingId "A6-ARCH-002" ;
  triage:title "ADR-008: boundaries/sc-lint/top-level-cli.toml missing logging.rs as approved RULE-001 entry point" ;
  triage:description "ADR-008 (RULE-001) requires that any crate module importing sc_observability must be listed as an approved entry point in its boundary TOML. crates/sc-lint/src/logging.rs imports sc_observability and is declared from main.rs (the approved binary entry). However, boundaries/sc-lint/top-level-cli.toml does not document logging.rs as the approved logging module in the boundary record. Sprint A.6 scope includes boundary record updates. Fix: add a logging.rs entry to the sc-lint boundary TOML under the approved entry points or composition section, per ADR-008 requirements." ;
  triage:category "ARCH" ;
  triage:phaseId "phase-A" ;
  triage:triageMode "initial_pass" ;
