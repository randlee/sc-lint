<urn:atm:triage:finding/ARCH-005>
  a triage:Finding ;
  triage:findingId "ARCH-005" ;
  triage:title "clear_atm_env does not set ATM_HOME/ATM_CONFIG_HOME to TempDir paths" ;
  triage:description "clear_atm_env removes ATM env vars but does not set ATM_HOME and ATM_CONFIG_HOME to isolated TempDir paths. Tests that call clear_atm_env may still read from the real user ATM config, causing non-deterministic behavior across environments." ;
  triage:phaseId "phase-A" ;
  triage:triageMode "initial_pass" ;
  triage:category "ARCH" ;
  triage:severity "important" ;
  triage:repeatable true ;
  triage:sweepScope "crate" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:references "PR #13" ;
  triage:references "QA-A4-002 FAIL report" ;
  triage:notes "Fix: update clear_atm_env to also set ATM_HOME and ATM_CONFIG_HOME to TempDir-based paths so tests are fully isolated." ;
  triage:hasOccurrence <urn:atm:triage:occurrence/ARCH-005/sprint-A4/1> ;
  triage:hasOccurrence <urn:atm:triage:occurrence/ARCH-005/sprint-A4/2> ;
  triage:openOn <urn:atm:triage:worktree/sprint-A4/b60b763> ;
  triage:promoteTo <urn:atm:triage:worktree/sprint-A4/b60b763> .

