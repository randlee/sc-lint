<urn:atm:triage:finding/A8-SC-002>
  a triage:Finding ;
  triage:findingId "A8-SC-002" ;
  triage:title "README.md misattributes PORT-001/002/003 rules to sc-lint-boundary" ;
  triage:description "README.md lines 96-101 lists PORT-001/002/003 under the sc-lint-boundary section. Per REQ-PRODUCT-004A and REQ-PRODUCT-015C these rules belong to sc-lint-portability. docs/sc-lint/README.md lines 143-151 is already correct. Fix: remove PORT-001/002/003 from sc-lint-boundary section in README.md; add sc-lint-portability section." ;
