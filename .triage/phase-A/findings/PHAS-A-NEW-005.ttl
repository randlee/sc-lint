<urn:atm:triage:finding/PHAS-A-NEW-005>
  a triage:Finding ;
  triage:findingId "PHAS-A-NEW-005" ;
  triage:title "RuntimeError.detail: String erases anyhow chain — inconsistent with BoundaryError/PortabilityError" ;
  triage:description "crates/sc-lint-runtime/src/lib.rs lines 74 and 76: RuntimeError variants AnalyzeFindings and CountScannedCrates carry a plain String detail field. The anyhow error chain is flattened via source.to_string() at call sites (lines 85, 91), erasing intermediate causes. BoundaryError and PortabilityError preserve the chain. This creates inconsistent error reporting across crates." ;
  triage:triageMode "initial_pass" ;
  triage:category "SC" ;
  triage:phaseId "phase-A" ;
  triage:severity "minor" ;
  triage:repeatable false ;
  triage:sweepScope "file_only" ;
  triage:status "open" ;
  triage:dispatchReady true ;
  triage:triagedAt "2026-05-10T00:00:00Z"^^xsd:dateTime ;
  triage:hasOccurrence <urn:atm:triage:occurrence/PHAS-A-NEW-005/integration-phase-A/1> ;
